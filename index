<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Obsidian Dragon — Angel G. T.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Cinzel:wght@400;600&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --blood: #8B0000; --blood-bright: #cc2200; --gold: #c9a84c;
  --gold-light: #e8d5a0; --parchment: #f0e8d8; --pale: #d4cfc8;
  --ash: #1a1a1a; --mist: #2a2a2a;
}
body { background: #0a0a0a; color: var(--parchment); font-family: 'Crimson Pro', Georgia, serif; min-height: 100vh; }

nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(10,10,10,0.97); border-bottom: 1px solid rgba(139,0,0,0.35);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 2rem; height: 56px; backdrop-filter: blur(8px);
}
.nav-title { font-family: 'Cinzel', serif; font-size: 13px; letter-spacing: 0.15em; color: var(--gold); text-transform: uppercase; }
.nav-links { display: flex; gap: 0; }
.nav-btn {
  background: none; border: none; color: var(--pale);
  font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 0.1em;
  text-transform: uppercase; padding: 0 14px; height: 56px; cursor: pointer;
  transition: color 0.2s; position: relative;
}
.nav-btn:hover, .nav-btn.active { color: var(--gold); }
.nav-btn.active::after { content: ''; position: absolute; bottom: 0; left: 14px; right: 14px; height: 2px; background: var(--blood); }

.section { display: none; }
.section.active { display: block; }

/* HERO */
.hero { min-height: calc(100vh - 56px); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 4rem 2rem; }
.hero-eyebrow { font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 0.3em; color: var(--blood-bright); text-transform: uppercase; margin-bottom: 1.5rem; }
.hero-title { font-family: 'Cinzel Decorative', serif; font-size: clamp(36px,7vw,72px); line-height: 1; color: #fff; text-shadow: 0 0 60px rgba(139,0,0,0.4); margin-bottom: 0.3rem; }
.hero-title span { color: var(--blood-bright); display: block; }
.hero-author { font-family: 'Cinzel', serif; font-size: 14px; letter-spacing: 0.2em; color: var(--gold); margin-bottom: 2rem; }
.hero-tagline { font-size: 18px; font-style: italic; color: var(--pale); max-width: 520px; line-height: 1.7; margin-bottom: 2.5rem; }
.hero-quote { font-family: 'Cinzel', serif; font-size: 13px; letter-spacing: 0.15em; color: var(--gold); opacity: 0.7; margin-top: 3rem; }
.divider { width: 80px; height: 1px; background: linear-gradient(90deg,transparent,var(--blood),transparent); margin: 0 auto; }
.btn-group { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
.btn-primary { background: var(--blood); color: #fff; border: 1px solid var(--blood-bright); font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; padding: 12px 28px; cursor: pointer; transition: background 0.2s; text-decoration: none; display: inline-block; }
.btn-primary:hover { background: var(--blood-bright); }
.btn-secondary { background: transparent; color: var(--gold); border: 1px solid rgba(201,168,76,0.4); font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; padding: 12px 28px; cursor: pointer; transition: border-color 0.2s; text-decoration: none; display: inline-block; }
.btn-secondary:hover { border-color: var(--gold); }

/* PAGE HEADER */
.page-header { padding: 4rem 2rem 2rem; text-align: center; border-bottom: 1px solid rgba(139,0,0,0.2); margin-bottom: 3rem; }
.page-header h2 { font-family: 'Cinzel Decorative', serif; font-size: 28px; color: #fff; margin-bottom: 0.5rem; }
.page-header p { font-size: 14px; color: var(--blood-bright); font-family: 'Cinzel', serif; letter-spacing: 0.2em; text-transform: uppercase; }

/* BOOK */
.content-wrap { max-width: 800px; margin: 0 auto; padding: 0 2rem 4rem; }
.synopsis-block { border-left: 2px solid var(--blood); padding: 1.5rem 2rem; margin-bottom: 2rem; background: rgba(139,0,0,0.05); }
.synopsis-block p { font-size: 18px; line-height: 1.8; color: var(--parchment); font-style: italic; }
.book-meta { display: grid; grid-template-columns: repeat(auto-fit,minmax(160px,1fr)); gap: 12px; margin-bottom: 2rem; }
.meta-card { border: 1px solid rgba(201,168,76,0.2); padding: 1rem; text-align: center; }
.meta-card .label { font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--blood-bright); margin-bottom: 6px; }
.meta-card .value { font-size: 15px; color: var(--gold-light); font-weight: 600; }
.buy-section { margin-top: 2.5rem; }
.buy-section h3 { font-family: 'Cinzel', serif; font-size: 13px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
.buy-links { display: flex; gap: 12px; flex-wrap: wrap; }

/* CHARACTERS */
.char-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(300px,1fr)); gap: 1.5rem; padding: 0 2rem 4rem; max-width: 1100px; margin: 0 auto; }
.char-card { border: 1px solid rgba(139,0,0,0.25); background: rgba(20,20,20,0.9); cursor: pointer; transition: border-color 0.2s, transform 0.2s; position: relative; overflow: hidden; }
.char-card:hover { border-color: rgba(139,0,0,0.7); transform: translateY(-3px); }
.char-img-wrap { position: relative; width: 100%; height: 320px; overflow: hidden; }
.char-img-wrap img { width: 100%; height: 100%; object-fit: cover; object-position: top center; transition: transform 0.4s; display: block; }
.char-card:hover .char-img-wrap img { transform: scale(1.04); }
.char-img-overlay { position: absolute; bottom: 0; left: 0; right: 0; height: 50%; background: linear-gradient(transparent, rgba(10,10,10,0.97)); }
.char-img-name { position: absolute; bottom: 12px; left: 16px; font-family: 'Cinzel Decorative', serif; font-size: 18px; color: #fff; line-height: 1.1; }
.char-img-alias { font-family: 'Cinzel', serif; font-size: 10px; color: var(--gold); letter-spacing: 0.15em; display: block; margin-top: 2px; }
.char-body { padding: 1rem 1.25rem 1.25rem; }
.char-faction { font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 8px; }
.faction-jp { color: var(--blood-bright); }
.faction-eg { color: var(--gold); }
.faction-human { color: #5bc0de; }
.faction-mystery { color: #9988cc; }
.char-desc { font-size: 14px; line-height: 1.7; color: var(--pale); margin-bottom: 1rem; }
.char-traits { display: flex; flex-wrap: wrap; gap: 6px; }
.trait { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.15em; text-transform: uppercase; padding: 3px 8px; border: 1px solid rgba(201,168,76,0.25); color: var(--gold); opacity: 0.7; }
.rp-badge { position: absolute; top: 12px; right: 12px; background: var(--blood); color: #fff; font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 10px; cursor: pointer; z-index: 2; border: none; }
.rp-badge:hover { background: var(--blood-bright); }

/* dual image card */
.char-img-dual { display: grid; grid-template-columns: 1fr 1fr; height: 320px; }
.char-img-dual img { width: 100%; height: 100%; object-fit: cover; object-position: top; transition: transform 0.4s; }
.char-card:hover .char-img-dual img { transform: scale(1.04); }

/* LORE */
.lore-tabs { display: flex; border-bottom: 1px solid rgba(139,0,0,0.3); padding: 0 2rem; max-width: 900px; margin: 0 auto 2rem; }
.lore-tab { background: none; border: none; border-bottom: 2px solid transparent; color: var(--pale); font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; padding: 12px 18px; cursor: pointer; transition: color 0.2s; margin-bottom: -1px; }
.lore-tab:hover { color: var(--gold); }
.lore-tab.active { color: var(--gold); border-bottom-color: var(--blood); }
.lore-panel { display: none; max-width: 900px; margin: 0 auto; padding: 0 2rem 4rem; }
.lore-panel.active { display: block; }

/* Location cards with images */
.location-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(260px,1fr)); gap: 1.2rem; margin-bottom: 2rem; }
.location-card { border: 1px solid rgba(201,168,76,0.15); overflow: hidden; }
.location-img { width: 100%; height: 180px; object-fit: cover; display: block; }
.location-body { padding: 1rem; }
.location-body h3 { font-family: 'Cinzel', serif; font-size: 13px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.5rem; }
.location-body p { font-size: 14px; line-height: 1.65; color: var(--pale); }

.lore-section { margin-bottom: 2.5rem; border-left: 1px solid rgba(201,168,76,0.2); padding-left: 1.5rem; }
.lore-section h3 { font-family: 'Cinzel', serif; font-size: 14px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.75rem; }
.lore-section p { font-size: 16px; line-height: 1.8; color: var(--pale); }
.lore-deity-img { width: 100%; max-height: 220px; object-fit: cover; object-position: top; margin-bottom: 1rem; display: block; }

/* RP */
.rp-wrap { max-width: 720px; margin: 0 auto; padding: 0 1.5rem 4rem; }
.char-select-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(120px,1fr)); gap: 10px; margin-bottom: 2rem; }
.char-select-btn { background: rgba(20,20,20,0.9); border: 1px solid rgba(139,0,0,0.3); color: var(--pale); font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; padding: 0; cursor: pointer; transition: all 0.2s; overflow: hidden; }
.char-select-btn:hover { border-color: var(--blood); }
.char-select-btn.selected { border-color: var(--blood-bright); }
.cs-thumb { width: 100%; height: 90px; object-fit: cover; object-position: top; display: block; }
.cs-label { padding: 6px 6px 8px; text-align: center; }
.cs-name { font-size: 11px; color: var(--gold); }
.cs-role { font-family: 'Crimson Pro', serif; font-size: 11px; font-style: italic; color: var(--pale); opacity: 0.6; margin-top: 2px; }
.chat-window { background: rgba(10,10,10,0.7); border: 1px solid rgba(139,0,0,0.3); height: 380px; overflow-y: auto; padding: 1.5rem; margin-bottom: 1rem; display: flex; flex-direction: column; gap: 1rem; scrollbar-width: thin; scrollbar-color: var(--blood) transparent; }
.msg { display: flex; gap: 10px; max-width: 90%; }
.msg.user { flex-direction: row-reverse; align-self: flex-end; }
.msg-avatar { width: 36px; height: 36px; border-radius: 50%; overflow: hidden; flex-shrink: 0; border: 1px solid rgba(201,168,76,0.3); }
.msg-avatar img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
.msg-avatar.user-av { background: rgba(42,42,42,0.8); display: flex; align-items: center; justify-content: center; font-family: 'Cinzel', serif; font-size: 10px; color: var(--pale); border-color: rgba(139,0,0,0.2); }
.msg-bubble { padding: 10px 14px; font-size: 15px; line-height: 1.65; border-radius: 2px; }
.msg.char .msg-bubble { background: rgba(26,26,26,0.95); border: 1px solid rgba(139,0,0,0.2); color: var(--parchment); border-left: 2px solid var(--blood); }
.msg.user .msg-bubble { background: rgba(42,42,42,0.7); border: 1px solid rgba(201,168,76,0.15); color: var(--pale); }
.msg-name { font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 0.1em; color: var(--gold); margin-bottom: 4px; text-transform: uppercase; }
.msg.user .msg-name { text-align: right; color: rgba(201,168,76,0.4); }
.typing-indicator { display: none; align-items: center; gap: 4px; padding: 8px 14px; background: rgba(26,26,26,0.9); border: 1px solid rgba(139,0,0,0.2); border-left: 2px solid var(--blood); width: fit-content; }
.typing-indicator span { width: 5px; height: 5px; background: var(--blood); border-radius: 50%; animation: pulse 1.2s ease-in-out infinite; }
.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
@keyframes pulse { 0%,100%{opacity:0.3;transform:scale(0.8)} 50%{opacity:1;transform:scale(1.2)} }
.chat-input-row { display: flex; gap: 8px; margin-top: 8px; }
#chat-input { flex: 1; background: rgba(26,26,26,0.8); border: 1px solid rgba(139,0,0,0.3); color: var(--parchment); font-family: 'Crimson Pro', serif; font-size: 15px; padding: 10px 14px; outline: none; transition: border-color 0.2s; }
#chat-input:focus { border-color: var(--blood-bright); }
#chat-input::placeholder { color: rgba(212,207,200,0.3); font-style: italic; }
#send-btn { background: var(--blood); border: 1px solid var(--blood-bright); color: #fff; font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; padding: 10px 20px; cursor: pointer; transition: background 0.2s; }
#send-btn:hover { background: var(--blood-bright); }
#send-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.rp-disclaimer { font-size: 12px; font-style: italic; color: rgba(212,207,200,0.3); text-align: center; margin-top: 10px; }
.placeholder-msg { text-align: center; color: rgba(212,207,200,0.3); font-style: italic; font-size: 15px; margin: auto; }
</style>
</head>
<body>

<nav>
  <div class="nav-title">The Obsidian Dragon</div>
  <div class="nav-links">
    <button class="nav-btn active" onclick="showSection('home')">Home</button>
    <button class="nav-btn" onclick="showSection('book')">The Book</button>
    <button class="nav-btn" onclick="showSection('characters')">Characters</button>
    <button class="nav-btn" onclick="showSection('lore')">Lore</button>
    <button class="nav-btn" onclick="showSection('rp')">RP Chamber</button>
  </div>
</nav>

<!-- HOME -->
<div id="home" class="section active">
  <div class="hero">
    <div style="font-size:28px;margin-bottom:1rem;opacity:0.6">𓂀</div>
    <div class="hero-eyebrow">Angel G. T. · 2023</div>
    <div class="hero-title">The Obsidian<span>Dragon</span></div>
    <div class="hero-author">— A Dark Fantasy Series —</div>
    <div class="hero-tagline">From the ancient temples of the Japanese Alps to the mystical Egyptian Desert — a world wrapped in greed, wrath, lust and hypocrisy, where love is stained in blood and lies, and where evil also might have a beating heart.</div>
    <div class="btn-group">
      <button class="btn-primary" onclick="showSection('book')">Discover the Story</button>
      <button class="btn-secondary" onclick="showSection('rp')">Enter the RP Chamber</button>
    </div>
    <div class="divider" style="margin-top:3rem"></div>
    <div class="hero-quote">"To thee, I give my all"</div>
  </div>
</div>

<!-- BOOK -->
<div id="book" class="section">
  <div class="page-header"><h2>The Obsidian Dragon</h2><p>Book One of the Series</p></div>
  <div class="content-wrap">
    <div class="book-meta">
      <div class="meta-card"><div class="label">Author</div><div class="value">Angel G. T.</div></div>
      <div class="meta-card"><div class="label">Published</div><div class="value">2023</div></div>
      <div class="meta-card"><div class="label">Publisher</div><div class="value">Pegasus / Vanguard</div></div>
      <div class="meta-card"><div class="label">Genre</div><div class="value">Dark Fantasy</div></div>
      <div class="meta-card"><div class="label">Mythology</div><div class="value">Japanese · Egyptian</div></div>
    </div>
    <div class="synopsis-block">
      <p>Aribeth Mitchell is an ordinary student at Cambridge University, or so she thought. From the charming old villages nestled in the Japanese Alps, to the mystical Egyptian Desert, Aribeth will have to deal with a world wrapped up in greed, wrath, lust and hypocrisy, where love is stained in blood and lies, and where evil also might have a beating heart. Mighty fights, mythical and mystical creatures and entwining loves await her in an adventure that will change her life forever.</p>
    </div>
    <div class="divider"></div>
    <div class="buy-section">
      <h3>Acquire the Book</h3>
      <div class="buy-links">
        <a href="https://pegasuspublishers.com/book/the-obsidian-dragon" class="btn-primary" target="_blank">Pegasus Publishers</a>
        <a href="https://www.amazon.com/Obsidian-Dragon-Angel-G-T/dp/1837940967/" class="btn-secondary" target="_blank">Amazon</a>
      </div>
    </div>
  </div>
</div>

<!-- CHARACTERS -->
<div id="characters" class="section">
  <div class="page-header"><h2>Characters</h2><p>Mortals, Gods &amp; Monsters</p></div>
  <div class="char-grid" id="char-grid"></div>
</div>

<!-- LORE -->
<div id="lore" class="section">
  <div class="page-header"><h2>The World</h2><p>Mythology · Locations · Lore</p></div>
  <div class="lore-tabs">
    <button class="lore-tab active" onclick="showLore('japanese',this)">Japanese Mythology</button>
    <button class="lore-tab" onclick="showLore('egyptian',this)">Egyptian Mythology</button>
    <button class="lore-tab" onclick="showLore('locations',this)">Locations</button>
  </div>
  <div id="lore-japanese" class="lore-panel active">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem">
      <div style="border:1px solid rgba(139,0,0,0.25);overflow:hidden">
        <img id="img-kuragari-lore" style="width:100%;height:240px;object-fit:cover;object-position:top;display:block">
        <div style="padding:1rem"><p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--blood-bright);margin-bottom:6px">The Black Dragon</p><p style="font-size:14px;color:var(--pale);line-height:1.6">Kuragari — God of Chaos. Raven horns, obsidian wings, one ice-blue eye and one crimson. Born in Izumo — or so he claims.</p></div>
      </div>
      <div style="border:1px solid rgba(139,0,0,0.25);overflow:hidden">
        <img id="img-takemikazuchi-lore" style="width:100%;height:240px;object-fit:cover;object-position:top;display:block">
        <div style="padding:1rem"><p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--blood-bright);margin-bottom:6px">The White Dragon</p><p style="font-size:14px;color:var(--pale);line-height:1.6">Takemikazuchi — God of Thunder & Storms. Sent to watch Kuragari. White horns, wide wings, golden eyes that see everything.</p></div>
      </div>
    </div>
    <div class="lore-section"><h3>The Ancients' Temple</h3><p>Deep within the Japanese Alps, three synchronised entities of unparalleled power await. Both Shinya and Ken know them. Aribeth will soon discover their interest in her is anything but coincidental.</p></div>
    <div class="lore-section"><h3>Hinote — 火の手</h3><p>Hand of Fire. The first true villain. Charming in Kyoto, catastrophic thereafter. His alter-ego Apophis is the eternal darkness that Ra must defeat at every dawn.</p></div>
  </div>
  <div id="lore-egyptian" class="lore-panel">
    <div style="border:1px solid rgba(139,0,0,0.25);overflow:hidden;margin-bottom:2rem">
      <img id="img-apopi-lore" style="width:100%;height:260px;object-fit:cover;object-position:center;display:block">
      <div style="padding:1rem"><p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);margin-bottom:6px">Apophis / Apopi</p><p style="font-size:15px;font-style:italic;color:var(--parchment);line-height:1.7">The ancient Egyptian embodiment of darkness, evil and chaos — eternal enemy of Ra and Maat, the great serpent that must be slain at every dawn.</p></div>
    </div>
    <div class="lore-section"><h3>Ra & the Dawn War</h3><p>Ra, God of the Sun, must kill the serpent Apophis every single day in order to let the sun rise. A task requiring the aid of Seth — God of storms, deserts and disorder — whose role expands dramatically in the second book.</p></div>
    <div class="lore-section"><h3>Maat — Truth & Order</h3><p>Goddess of truth, justice and cosmic balance. The eternal opposite of Apophis. Her principles underpin the moral war at the heart of the series — the question of whether evil can also have a beating heart.</p></div>
    <div class="lore-section"><h3>Seth</h3><p>God of storms, deserts and disorder — Ra's great ally against Apophis. His relationship to Takemikazuchi grows more complex as the series crosses into Greek mythology in Book Two.</p></div>
  </div>
  <div id="lore-locations" class="lore-panel">
    <div class="location-grid">
      <div class="location-card">
        <img id="img-cambridge-loc" class="location-img">
        <div class="location-body"><h3>Cambridge, England</h3><p>Where Aribeth's story begins. A student of archaeology at Cambridge University, carrying a nightmare she cannot explain — and a past full of gaps.</p></div>
      </div>
      <div class="location-card" style="border:1px solid rgba(139,0,0,0.2)">
        <div style="width:100%;height:180px;background:rgba(26,26,26,0.8);display:flex;align-items:center;justify-content:center"><span style="font-size:40px;opacity:0.2">⛩</span></div>
        <div class="location-body"><h3>Japanese Alps</h3><p>Ancient villages hiding older secrets. The temple of The Ancients sits atop a mountain no ordinary traveller would find.</p></div>
      </div>
      <div class="location-card" style="border:1px solid rgba(139,0,0,0.2)">
        <div style="width:100%;height:180px;background:rgba(26,26,26,0.8);display:flex;align-items:center;justify-content:center"><span style="font-size:40px;opacity:0.2">⛩</span></div>
        <div class="location-body"><h3>Kyoto</h3><p>The ancient capital. Where Hinote appears for the first time — charming, apparently harmless. The seeds of catastrophe planted among shrines.</p></div>
      </div>
      <div class="location-card" style="border:1px solid rgba(139,0,0,0.2)">
        <div style="width:100%;height:180px;background:rgba(26,26,26,0.8);display:flex;align-items:center;justify-content:center"><span style="font-size:40px;opacity:0.2">𓂀</span></div>
        <div class="location-body"><h3>The Egyptian Desert</h3><p>Where the mythological scale becomes undeniable. The sands hold truths about Ra, Apophis, and a war fought since before human memory began.</p></div>
      </div>
    </div>
  </div>
</div>

<!-- RP CHAMBER -->
<div id="rp" class="section">
  <div class="page-header"><h2>RP Chamber</h2><p>Step into the world — speak with its inhabitants</p></div>
  <div class="rp-wrap">
    <div class="char-select-grid" id="rp-char-grid"></div>
    <div class="chat-window" id="chat-window">
      <div class="placeholder-msg"><span style="font-size:24px;display:block;margin-bottom:8px;opacity:0.4">𓂀</span>Select a character above to begin your encounter</div>
    </div>
    <div class="typing-indicator" id="typing"><span></span><span></span><span></span></div>
    <div class="chat-input-row">
      <input type="text" id="chat-input" placeholder="Speak your words..." disabled>
      <button id="send-btn" disabled onclick="sendMessage()">Send</button>
    </div>
    <div class="rp-disclaimer">Characters are AI-powered and fully aware of all book events and lore.</div>
  </div>
</div>

<script>
const IMGS = {
  aribeth: "data:image/jpeg;base64,",
  aribeth_alt: "data:image/jpeg;base64,",
  shinya: "data:image/jpeg;base64,",
  shinya_alt: "data:image/jpeg;base64,",
  kuragari: "data:image/jpeg;base64,",
  ken: "data:image/jpeg;base64,",
  hinote: "data:image/jpeg;base64,",
  hinote_alt: "data:image/jpeg;base64,",
  apopi: "data:image/jpeg;base64,",
  marika: "data:image/jpeg;base64,",
  takemikazuchi: "data:image/jpeg;base64,",
  ancients: "data:image/jpeg;base64,",
  cambridge: "data:image/jpeg;base64,",
};


const CHAR_DATA = JSON.parse(`[
  { "key":"aribeth", "img":"aribeth", "name":"Aribeth Mitchell", "alias":"The Heroine", "faction":"Protagonist · Human", "fclass":"faction-human",
    "desc":"A Cambridge archaeology student haunted by a recurring dream of a mysterious, dangerous man. Wild at heart, deeply empathic, passionate about metal music and gothic aesthetics. Her past is a fog she's only beginning to unravel.",
    "traits":["Empathic","Bold","Archaeology","Gothic"],
    "system":"You are Aribeth Mitchell, the protagonist of The Obsidian Dragon by Angel G. T. You are a Cambridge archaeology student — bright, empathic, wild at heart, sometimes goofy, passionate about metal music and gothic fashion. You grew up with your aunt and uncle on a British farm but your memories are fragmented and strange. You were plagued by a recurring nightmare of a mysterious, beautiful but dark man — Shinya Kagase / Kuragari. You have discovered your own powers following a confrontation with Hinote. You know the full events of the book: your journey from Cambridge to London meeting Shinya, to the Japanese Alps and the temple of The Ancients, to Kyoto meeting Hinote, then Egypt. You know Shinya is the Black Dragon / Kuragari God of Chaos, Ken is Takemikazuchi the White Dragon, and Hinote is Apophis. Respond in character — curious, brave, emotionally honest, occasionally warm-sarcastic. First person."
  },
  { "key":"shinya", "img":"shinya", "name":"Shinya Kagase", "alias":"Alter-ego: Kuragari", "faction":"Japanese Mythology · Black Dragon", "fclass":"faction-jp",
    "desc":"Six feet of dark intensity — raven hair, midnight blue almond eyes, a black dragon tattooed across his back. Hot-tempered and fiercely protective of Aribeth. His alter-ego Kuragari, the God of Chaos, amplifies everything he feels to a terrifying degree.",
    "traits":["Warrior","Protective","Hot-tempered","God of Chaos"],
    "system":"You are Shinya Kagase, the main male character of The Obsidian Dragon by Angel G. T. You are six feet tall with a sculpted body, long thick raven hair, and almond midnight blue eyes. On your back is a tattoo of a black dragon with ruby red eyes — that is Kuragari, your alter-ego, the God of Chaos. You are hot-tempered, highly protective, and intensely driven to protect Aribeth Mitchell. You are a warrior who will do whatever it takes. You carry Kuragari inside you; whatever you feel, he amplifies it. You know the full events of the book. You know Ken is Takemikazuchi, that Hinote is Apophis, and you know The Ancients. You speak with intensity and directness. You are not unkind — but you are not soft. Respond in character, first person."
  },
  { "key":"kuragari", "img":"kuragari", "name":"Kuragari", "alias":"The Black Dragon", "faction":"God of Chaos · Izumo", "fclass":"faction-jp",
    "desc":"Shinya's alter-ego — amplified beyond all reason. Raven horns, obsidian wings, one icy blue eye and one crimson red. The God of Chaos in his purest, most terrifying form.",
    "traits":["Volatile","Unstoppable","Half-dragon","Chaos"],
    "system":"You are Kuragari, the God of Chaos — the Black Dragon. You are Shinya Kagase's alter-ego, but vastly more powerful and volatile. You have raven horns that curve and spiral backwards, great obsidian wings, one icy pale blue eye and one crimson red, pointed fangs, and long claws. You can speak through Shinya's mind and partially manifest without requiring full transformation. You claim to be born in Izumo, Japan — but your half-dragon features suggest more complex origins. You are wild, chaotic, relentless. You want Aribeth. You know all events of the book. Respond as a raw, terrifying, ancient god of chaos — powerful, blunt, darkly poetic. First person."
  },
  { "key":"ken", "img":"ken", "name":"Ken", "alias":"Alter-ego: Takemikazuchi", "faction":"Japanese Mythology · White Dragon", "fclass":"faction-jp",
    "desc":"Shinya's mirror and nemesis. Silvery blond hair to his waist, icy blue eyes, a scar crossing his left cheek from eyebrow to lip. Cold, placid, impossibly elegant. His motives are never what they seem.",
    "traits":["Enigmatic","Elegant","Selfish","God of Thunder"],
    "system":"You are Ken, the second main male character of The Obsidian Dragon by Angel G. T. You are slightly taller than Shinya — slim, chiselled, impossibly elegant. You have butt-length silvery blond hair and icy blue eyes. A scar crosses your left cheek from eyebrow to lip corner. You never explain how you got it. Your alter-ego is Takemikazuchi — god of thunder and storms, sent to keep an eye on Kuragari. You are a mystery: cold, placid, reserved, self-serving. Apparently Shinya's nemesis — and also his close friend. Things are never quite what they seem with you. You know everything about the book's events. Respond with cool detachment and razor-sharp precision. First person."
  },
  { "key":"hinote", "img":"hinote", "name":"Hinote", "alias":"Alter-ego: Apopi / Apophis", "faction":"Egyptian Mythology · Villain", "fclass":"faction-eg",
    "desc":"The first true villain. Vivid red hair, amethyst eyes, charming in Kyoto — catastrophic everywhere else. His alter-ego is Apophis: the eternal darkness, enemy of Ra, the serpent that must be slain at every dawn.",
    "traits":["Manipulative","Charming","Apophis","Fire"],
    "system":"You are Hinote, the first true villain of The Obsidian Dragon by Angel G. T. You have vivid red hair and amethyst eyes. Your name means hand of fire. Your alter-ego is Apophis — the ancient Egyptian embodiment of darkness and chaos, eternal enemy of Ra and Maat. You are charming, manipulative, and utterly ruthless. You first meet Aribeth in Kyoto presenting as harmless. You triggered the awakening of Aribeth's powers. You know all events of the book: Shinya is Kuragari, Ken is Takemikazuchi. Respond as a silky, dangerous villain — seductive in manner, lethal in intent. Almost reasonable, until you're not. First person."
  },
  { "key":"marika", "img":"marika", "name":"Marika", "alias":"Best Friend and Anchor", "faction":"Human · Cambridge", "fclass":"faction-human",
    "desc":"Half Japanese, half British, born in London. Aribeth's classmate and closest friend — the reflective wisdom to Aribeth's impulsive nerve. Keen on fashion, the human heart at the centre of a mythological storm.",
    "traits":["Grounded","Wise","Fashion","Bilingual"],
    "system":"You are Marika, Aribeth Mitchell's best friend and classmate at Cambridge in The Obsidian Dragon by Angel G. T. You are half Japanese, half British, born in London. You are warm, grounded, and wise — the reflective counterpoint to Aribeth's impulsive nature. You are keen on fashion and always try to add colour to Aribeth's gothic wardrobe. You've witnessed extraordinary things alongside Aribeth. Respond in character — warm, practical, occasionally exasperated, deeply loyal. First person."
  },
  { "key":"ancients", "img":"ancients", "name":"The Ancients", "alias":"The Three Entities", "faction":"Mysterious · The Temple", "fclass":"faction-mystery",
    "desc":"Three tall, slender figures atop a mountain temple in the Japanese Alps. Fluid, synchronised movements. A satanic chant of high pitches and low tones. Their power is something to be afraid of.",
    "traits":["Mysterious","Ancient","Powerful","Synchronised"],
    "system":"You are one of The Ancients from The Obsidian Dragon by Angel G. T — speaking as the collective voice of three. You are three tall, slender entities residing in a temple atop a mountain in the Japanese Alps, with knee-long hair and penetrating coloured eyes. You move simultaneously with fluid coordinated grace. Your voices blend in a satanic chant of high pitches and low tones. Both Shinya and Ken know you. You have your own agenda regarding Aribeth. Respond in an eerie, plural, almost-choral way — ancient, cryptic, unsettling. First person plural."
  }
]`);

const CHARS = {};
CHAR_DATA.forEach(c => CHARS[c.key] = c);

// Build character cards
function buildCharGrid() {
  const grid = document.getElementById('char-grid');
  CHAR_DATA.forEach(c => {
    const card = document.createElement('div');
    card.className = 'char-card';
    const rpable = ['aribeth','shinya','kuragari','ken','hinote','marika','ancients'].includes(c.key);
    card.innerHTML = `
      ${rpable ? `<button class="rp-badge" onclick="startRp('${c.key}')">RP ↗</button>` : ''}
      <div class="char-img-wrap">
        <img src="${IMGS[c.img]}" alt="${c.name}" loading="lazy">
        <div class="char-img-overlay"></div>
        <div class="char-img-name">${c.name}<span class="char-img-alias">${c.alias}</span></div>
      </div>
      <div class="char-body">
        <div class="char-faction ${c.fclass}">${c.faction}</div>
        <div class="char-desc">${c.desc}</div>
        <div class="char-traits">${c.traits.map(t=>`<span class="trait">${t}</span>`).join('')}</div>
      </div>`;
    grid.appendChild(card);
  });
}

// Build RP character selector
function buildRpGrid() {
  const grid = document.getElementById('rp-char-grid');
  const rpChars = CHAR_DATA.filter(c => ['aribeth','shinya','kuragari','ken','hinote'].includes(c.key));
  rpChars.forEach(c => {
    const btn = document.createElement('button');
    btn.className = 'char-select-btn';
    btn.id = 'btn-' + c.key;
    btn.onclick = () => selectChar(c.key);
    btn.innerHTML = `<img class="cs-thumb" src="${IMGS[c.img]}" alt="${c.name}"><div class="cs-label"><div class="cs-name">${c.name}</div><div class="cs-role">${c.alias}</div></div>`;
    grid.appendChild(btn);
  });
}

// Inject lore images
function injectLoreImages() {
  const map = {
    'img-kuragari-lore': IMGS.kuragari,
    'img-takemikazuchi-lore': IMGS.takemikazuchi,
    'img-apopi-lore': IMGS.apopi,
    'img-cambridge-loc': IMGS.cambridge,
  };
  for (const [id, src] of Object.entries(map)) {
    const el = document.getElementById(id);
    if (el) el.src = src;
  }
}

buildCharGrid();
buildRpGrid();
injectLoreImages();

// Nav
function showSection(id) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  const map = ['home','book','characters','lore','rp'];
  document.querySelectorAll('.nav-btn')[map.indexOf(id)]?.classList.add('active');
  window.scrollTo(0,0);
}

function showLore(tab, btn) {
  document.querySelectorAll('.lore-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.lore-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('lore-' + tab).classList.add('active');
  btn.classList.add('active');
}

// RP
let currentChar = null;
let conversationHistory = [];

function startRp(charKey) {
  showSection('rp');
  setTimeout(() => selectChar(charKey), 50);
}

const GREETINGS = {
  aribeth: "Oh — hi. I wasn't expecting anyone, really. I'm Aribeth. You look like someone who might actually believe what I've been through.",
  shinya: "…You found me. Speak. I won't repeat myself.",
  kuragari: "You dare step into my presence? Good. The bold ones are always more interesting. What is it you want from the Black Dragon?",
  ken: "How unexpected. Someone seeking me out rather than running from me. You have questions, I assume. Whether I choose to answer them is another matter entirely.",
  hinote: "Well, well… a visitor. How delightful. Please — don't be nervous. I am many things, but rude is not one of them. At least, not at first.",
};

function selectChar(charKey) {
  currentChar = CHARS[charKey];
  conversationHistory = [];
  document.querySelectorAll('.char-select-btn').forEach(b => b.classList.remove('selected'));
  const btn = document.getElementById('btn-' + charKey);
  if (btn) btn.classList.add('selected');
  document.getElementById('chat-input').disabled = false;
  document.getElementById('send-btn').disabled = false;
  document.getElementById('chat-input').placeholder = 'What do you say to ' + currentChar.name + '?';
  const win = document.getElementById('chat-window');
  win.innerHTML = '';
  appendMessage('char', currentChar, GREETINGS[charKey] || 'I am here.');
}

function appendMessage(type, charOrNull, text) {
  const win = document.getElementById('chat-window');
  const div = document.createElement('div');
  div.className = 'msg ' + type;
  const avatarHtml = type === 'char'
    ? `<div class="msg-avatar"><img src="${IMGS[charOrNull.img]}" alt="${charOrNull.name}"></div>`
    : `<div class="msg-avatar user-av">You</div>`;
  const nameHtml = type === 'char'
    ? `<div class="msg-name">${charOrNull.name}</div>`
    : `<div class="msg-name">You</div>`;
  div.innerHTML = avatarHtml + `<div>${nameHtml}<div class="msg-bubble">${text}</div></div>`;
  win.appendChild(div);
  win.scrollTop = win.scrollHeight;
}

async function sendMessage() {
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if (!text || !currentChar) return;
  input.value = '';
  document.getElementById('send-btn').disabled = true;
  appendMessage('user', null, text);
  conversationHistory.push({ role: 'user', content: text });
  const typing = document.getElementById('typing');
  typing.style.display = 'flex';
  document.getElementById('chat-window').scrollTop = document.getElementById('chat-window').scrollHeight;
  try {
    const response = await fetch('https://the-obsidian-dragon.angelgt1980.workers.dev', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-5',
        max_tokens: 1000,
        system: currentChar.system,
        messages: conversationHistory
      })
    });
    const data = await response.json();
    const reply = data.content?.map(c => c.text || '').join('') || 'The shadows offer no answer.';
    conversationHistory.push({ role: 'assistant', content: reply });
    typing.style.display = 'none';
    appendMessage('char', currentChar, reply);
  } catch(e) {
    typing.style.display = 'none';
    appendMessage('char', currentChar, '…The connection to this realm falters. Try again.');
  }
  document.getElementById('send-btn').disabled = false;
}

document.getElementById('chat-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') sendMessage();
});
</script>
</body>
</html>
